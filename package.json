{
  "name": "eisdealer",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "scrape": "bun run packages/scraper/src/index.ts",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "typecheck": "tsc --noEmit && tsc --noEmit -p packages/scraper/tsconfig.json",
    "knip": "knip",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@fontsource/space-grotesk": "5.2.10",
    "@plausible-analytics/tracker": "0.4.5",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-router": "1.170.10",
    "@tanstack/react-start": "1.168.17",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "knip": "6.14.2",
    "lefthook": "2.1.9",
    "typescript": "6.0.3",
    "vite": "8.0.14"
  }
}
