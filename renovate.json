{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"timezone": "Europe/Berlin",
	"extends": [
		"config:best-practices",
		"group:monorepos",
		"group:recommended",
		":automergeMinor"
	],
	"assignees": ["phlgr"],
	"packageRules": [
		{
			"matchDepTypes": ["devDependencies"],
			"automerge": true
		},
		{
			"groupName": "playwright",
			"matchPackageNames": ["playwright", "playwright-core", "mcr.microsoft.com/playwright"]
		}
	]
}
